{
  "name": "tkbank",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "audit:room": "node modules/room-audit/index.js",
    "audit:review": "node modules/room-audit/generate-review-sample.js",
    "audit:review:score": "node modules/room-audit/score-review-sample.js",
    "run:daily": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-daily.ps1 -EntryScript \"scripts/run-all-daily.js\" -LogPrefix \"all-run\"",
    "run:daily:room-audit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-daily.ps1 -EntryScript \"modules/room-audit/index.js\" -LogPrefix \"room-audit-run\"",
    "run:trong-kin": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-daily.ps1 -EntryScript \"index.js\" -LogPrefix \"trong-kin-run\"",
    "run:room-audit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-daily.ps1 -EntryScript \"modules/room-audit/index.js\" -LogPrefix \"room-audit-run\"",
    "run:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-daily.ps1 -EntryScript \"scripts/run-all-daily.js\" -LogPrefix \"all-run\"",
    "run:trong-kin-then-room-audit": "npm run run:all",
    "schedule:daily": "powershell -ExecutionPolicy Bypass -File .\\scripts\\register-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\" -EntryScript \"scripts/run-all-daily.js\" -LogPrefix \"all-run\"",
    "schedule:daily:room-audit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\register-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\" -EntryScript \"scripts/run-all-daily.js\" -LogPrefix \"all-run\"",
    "schedule:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\"",
    "schedule:stop:room-audit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-daily-task.ps1 -TaskName \"ToolUpdateRoom-RoomAudit-Daily\"",
    "schedule:stop:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\"",
    "schedule:create:trong-kin": "powershell -ExecutionPolicy Bypass -File .\\scripts\\register-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\" -EntryScript \"scripts/run-all-daily.js\" -LogPrefix \"all-run\"",
    "schedule:cancel:trong-kin": "powershell -ExecutionPolicy Bypass -File .\\scripts\\remove-daily-task.ps1 -TaskName \"ToolUpdateRoom-TrongKin-Daily\"",
    "schedule:create:room-audit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\register-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\" -EntryScript \"scripts/run-all-daily.js\" -LogPrefix \"all-run\"",
    "schedule:cancel:room-audit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\remove-daily-task.ps1 -TaskName \"ToolUpdateRoom-RoomAudit-Daily\"",
    "schedule:create:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\register-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\" -EntryScript \"scripts/run-all-daily.js\" -LogPrefix \"all-run\"",
    "schedule:cancel:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\remove-daily-task.ps1 -TaskName \"ToolUpdateRoom-All-Daily\"",
    "schedule:cleanup:legacy": "powershell -ExecutionPolicy Bypass -Command \"$tasks=@('ToolUpdateRoom-TrongKin-Daily','ToolUpdateRoom-RoomAudit-Daily','ToolUpdateRoom-TwiceDaily'); foreach($t in $tasks){ schtasks /Query /TN $t *> $null; if($LASTEXITCODE -eq 0){ schtasks /Delete /TN $t /F *> $null; Write-Host \\\"[scheduler] Deleted $t\\\" } else { Write-Host \\\"[scheduler] Skip missing $t\\\" } }\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "axios": "^1.7.2",
    "csvtojson": "^2.0.10",
    "dayjs": "^1.11.13",
    "dotenv": "^17.4.2",
    "fuse.js": "^6.6.2",
    "googleapis": "^137.1.0",
    "heic-convert": "^2.1.0",
    "leven": "^3.1.0",
    "mammoth": "^1.12.0",
    "minio": "^8.0.5",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.2",
    "npm": "^10.8.1",
    "openai": "^4.85.2",
    "xlsx": "^0.18.5"
  }
}
